# 사이트 기본 URL (배포 후 변경)
NEXT_PUBLIC_SITE_URL=https://barun-janglae.vercel.app

# 문의 폼 수신 이메일 (api/contact 라우트에서 사용 예정)
CONTACT_TO_EMAIL=team@barun-janglae.com

# (옵션) Resend API 키 — Resend 연동 시 사용
# RESEND_API_KEY=re_xxxxx

# (옵션) EmailJS 사용 시 클라이언트 측 키
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
